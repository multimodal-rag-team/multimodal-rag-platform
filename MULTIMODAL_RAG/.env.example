# =============================================================================
# Multimodal RAG — copy this file to .env and fill in your values
# =============================================================================

# --- PostgreSQL (pgvector) ---
DATABASE_URL=DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/multimodal_rag

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_ROUTER_MODEL=gpt-4o-mini
OPENAI_ANSWER_MODEL=gpt-4o-mini
OPENAI_TABLE_DESCRIPTION_MODEL=gpt-4o-mini

# --- PDF parser ---
UNSTRUCTURED_STRATEGY=fast
IMAGE_OUTPUT_DIR=
USE_LLM_TABLE_DESCRIPTIONS=true

# --- RAG retrieval ---
RAG_TOP_K=5

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
UPLOAD_DIR=data/uploads

# --- Langfuse (optional — leave empty to disable tracing) ---
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST=https://cloud.langfuse.com
